{
  "name": "sip-docs",
  "main": "./worker.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    }
  },
  "routes": [
    {
      "pattern": "sip.standardagents.ai",
      "custom_domain": true
    }
  ],
  "assets": {
    "binding": "ASSETS"
  }
}
